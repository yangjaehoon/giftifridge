{
  "name": "giftifridge",
  "version": "1.0.0",
  "main": "index.ts",
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "9.1.0",
    "@react-native-community/netinfo": "12.0.1",
    "@react-native-ml-kit/text-recognition": "^2.0.0",
    "@react-navigation/bottom-tabs": "^7.18.8",
    "@react-navigation/native": "^7.3.8",
    "@react-navigation/native-stack": "^7.17.10",
    "expo": "~57.0.6",
    "expo-camera": "~57.0.3",
    "expo-device": "~57.0.1",
    "expo-file-system": "~57.0.1",
    "expo-image-picker": "~57.0.4",
    "expo-location": "~57.0.4",
    "expo-notifications": "~57.0.5",
    "expo-status-bar": "~57.0.1",
    "firebase": "^12.16.0",
    "react": "19.2.3",
    "react-native": "0.86.0",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@firebase/rules-unit-testing": "^5.0.1",
    "@testing-library/react-native": "^14.0.1",
    "@types/jest": "29.5.14",
    "@types/node": "^26.1.1",
    "@types/react": "~19.2.2",
    "eslint": "^9.0.0",
    "eslint-config-expo": "~57.0.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "jest": "~29.7.0",
    "jest-expo": "~57.0.2",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.5",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "start": "expo start",
    "predev": "node scripts/ensure-emulator.js",
    "dev": "expo start --dev-client --android",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "jest",
    "test:rules": "firebase emulators:exec --only firestore \"jest --config jest.rules.config.js\"",
    "prepare": "husky"
  },
  "private": true,
  "jest": {
    "preset": "jest-expo",
    "testPathIgnorePatterns": [
      "<rootDir>/node_modules/",
      "<rootDir>/firestore.rules.test.ts"
    ]
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
